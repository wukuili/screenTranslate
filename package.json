{
  "name": "screen-translate",
  "version": "0.1.0",
  "private": true,
  "description": "Windows-first screenshot translation desktop client.",
  "author": "Screen Translate contributors",
  "main": "out/main/index.js",
  "packageManager": "npm@11.11.0",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "build": {
    "appId": "com.screentranslate.app",
    "productName": "Screen Translate",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Screen Translate"
    }
  },
  "dependencies": {
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.15.3",
    "electron-vite": "^4.0.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.6",
    "vitest": "^4.0.15"
  }
}
